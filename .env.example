# Copy to .env and fill in. Use with Dockge env or: docker compose --env-file .env up
# Windows credentials are entered at login (not stored in env).

# Windows DNS server (WinRM) - host only; user/password come from the login form
WINDOWS_DNS_HOST=192.168.1.10
# Use HTTPS WinRM (port 5986); if false, uses HTTP 5985
WINRM_USE_HTTPS=false
# WINRM_PORT=5985
# Transport for pywinrm from Linux: ntlm (default; use when WinRM Basic=false), basic, kerberos, credssp
# WINRM_TRANSPORT=ntlm

# JWT signing (use a long random secret in production)
SECRET_KEY=use-a-long-random-secret-here
